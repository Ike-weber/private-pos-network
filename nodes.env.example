# Example IP configuration for 9 distributed nodes.
# Copy this to nodes.env and fill in your actual machine IPs.

# Seed node (machine 1) - starts first, others connect to it
SEED_NODE_ID=1
SEED_MACHINE_IP=10.0.0.1
SEED_BEACON_IP=10.0.0.1
SEED_BEACON_P2P_PORT=13000
SEED_BEACON_PEER_ID=          # fill after machine 1 starts

# All node IPs (used for monitoring or ansible/ssh loops)
NODE1_IP=10.0.0.1
NODE2_IP=10.0.0.2
NODE3_IP=10.0.0.3
NODE4_IP=10.0.0.4
NODE5_IP=10.0.0.5
NODE6_IP=10.0.0.6
NODE7_IP=10.0.0.7
NODE8_IP=10.0.0.8
NODE9_IP=10.0.0.9
